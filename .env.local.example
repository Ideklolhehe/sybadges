# Copy this file to .env.local and fill in the values for local development.
# .env.local is git-ignored and must never be committed.

# ── Database ────────────────────────────────────────────────────────────────────
# DATABASE_URL="file:./dev.db"

# ── Auth ────────────────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET="change-me"
# NEXTAUTH_URL="http://localhost:3000"

# ── Dev-only features ───────────────────────────────────────────────────────────
# Code Translator — developer tool only, excluded from the published web app.
# Set both variables to 'true' to enable it locally.
# ENABLE_CODE_TRANSLATOR=true
# NEXT_PUBLIC_ENABLE_CODE_TRANSLATOR=true
